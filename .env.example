# ========================================
# GuardianIA v3.0 - Configuración de Entorno
# Base de Datos: MySQL via AppServ / phpMyAdmin
# ========================================

# Modo local (AppServ/XAMPP) o producción
IS_LOCAL=true

# ========================================
# CONFIGURACIÓN MySQL - AppServ / phpMyAdmin
# ========================================
# Host de MySQL (por defecto localhost en AppServ)
DB_HOST=localhost

# Usuario de MySQL (por defecto 'root' en AppServ)
DB_USER=root

# Contraseña de MySQL (vacía por defecto en AppServ, o la que configuraste)
DB_PASS=

# Nombre de la base de datos (créala en phpMyAdmin)
DB_NAME=guardianai_local

# Puerto de MySQL (por defecto 3306 en AppServ)
DB_PORT=3306

# ========================================
# CONFIGURACIÓN PRODUCCIÓN (Hosting)
# Descomenta estas líneas si usas hosting
# ========================================
# DB_PRIMARY_HOST=localhost
# DB_PRIMARY_USER=guardia2_ander
# DB_PRIMARY_PASS=tu_contraseña_aqui
# DB_PRIMARY_NAME=guardia2_guardianai_db
# DB_PRIMARY_PORT=3306

# ========================================
# SEGURIDAD
# ========================================
# Clave secreta de Flask (se genera automáticamente si no se define)
# SECRET_KEY=tu_clave_secreta_aqui

# URL de la aplicación
APP_URL=http://localhost:5000

# Contraseñas de usuarios por defecto
DEFAULT_USER_ANDERSON_PASS=Ander12345@
DEFAULT_USER_ADMIN_PASS=admin123
